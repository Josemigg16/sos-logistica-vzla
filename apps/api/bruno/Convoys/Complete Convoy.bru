meta {
  name: Complete Convoy
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/convoys/:id/complete
  body: none
  auth: bearer
}

params:path {
  id: 00000000-0000-0000-0000-000000000001
}

auth:bearer {
  token: {{accessToken}}
}

docs {
  Completa la caravana: EN_RUTA → ENTREGADO. Requiere rol ZODI_SENDER.

  409 con `code: "INVALID_TRANSITION"` si el estado no lo permite.
}
