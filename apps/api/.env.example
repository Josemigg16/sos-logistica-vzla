# Variables que consume la API (bun dev:api).
# NO pongas VITE_* acá: esas las hornea Vite en el frontend, la API no las lee.
# Copiá a .env y ajustá. Todos los valores tienen default en src/config.ts;
# acá van los del entorno de desarrollo local.

# Conexión a Postgres.
DATABASE_URL=postgresql://sos:sos@localhost:5432/sos_logistica

# Puerto donde escucha la API.
PORT=8081

# Origen del frontend permitido por CORS (Vite dev corre en 5173).
WEB_ORIGIN=http://localhost:5173

# Secretos — generá valores largos y aleatorios. NUNCA uses estos en producción.
JWT_SECRET=cambiar-por-secreto-largo-aleatorio
API_SECRET=cambiar-por-secreto-largo-aleatorio

# Credenciales del admin inicial que crea `bun run seed`.
SEED_ADMIN_USER=admin
SEED_ADMIN_PASS=changeme123
