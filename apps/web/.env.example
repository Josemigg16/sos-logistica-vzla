# Única variable que consume el frontend. Vite la hornea en el bundle en build time,
# así que NO puede ser localhost en producción: es la URL pública con la que el
# navegador llega a la API. Copiá a .env y ajustá.
#
# Debe terminar en /api (la API monta sus rutas bajo ese prefijo).
#   dev  -> http://localhost:8081/api
#   prod -> https://api.tudominio.com/api
VITE_API_URL=http://localhost:8081
