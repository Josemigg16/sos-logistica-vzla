  # Copia a .env y ajustá. docker-compose lee estas variables desde la 
  carpeta del repo.
  # Modelo carpeta-por-entorno: un clon del repo por entorno (/srv/sos-dev, /srv/sos-test),
  # cada carpeta con su propio .env
  
  DB_PORT=5432 
  API_PORT=8081
  WEB_PORT=8080

  # Base de datos de ESTE entorno (usá claves distintas por entorno).
  POSTGRES_USER=sos
  POSTGRES_PASSWORD=sos
  POSTGRES_DB=sos_logistica

  # URL PÚBLICA que el navegador usa para llegar a la API (Vite la hornea 
  en build; NO localhost).
  # Debe coincidir EXACTO con el server_name del bloque api en 
  docker/nginx-host.example.conf.
  #   dev  -> https://api.dev.tudominio.com
  #   test -> https://api.test.tudominio.com
  VITE_API_URL=http://localhost:8081
  
  # Claves secretas de la API — PONÉ PLACEHOLDERS ACÁ, NO los valores 
  reales (ver abajo).
  JWT_SECRET=cambiar-por-secreto-largo-aleatorio
  API_SECRET=cambiar-por-secreto-largo-aleatorio