# Copy to .env and adjust. docker-compose reads these.
POSTGRES_USER=sos
POSTGRES_PASSWORD=sos
POSTGRES_DB=sos_logistica

# Public URL the browser uses to reach the API (baked into the web build).
# Match it to where your global nginx exposes the api port.
VITE_API_URL=http://localhost:8081

# Claves secretas de la API (Copiar y ajustar en tu .env)
JWT_SECRET=super-secret-jwt-key-2026-sos-logistica
API_SECRET=mi-secreto-super-seguro-para-tokens-externos
